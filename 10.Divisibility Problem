#include<iostream>
#include<vector>
using namespace std;
int main(){
    int a;
    int b;
    int t;
    cin>>t;
    vector<int> counter(t);
    for(int w=0;w<t;w++){
        cin>>a;
        cin>>b;
        if(a%b==0){
        counter[w]=0;
    }
    else{
        int con=0;
    con = b - (a % b);
    counter[w]=con;
    }
  }
for(int x:counter){
    cout<<x<<"\n";
}
    
    return 0;
}

