#include<iostream>
#include<string>
using namespace std;
int main(){
    string num;
    cin>>num;
    int count = 0;
    for(int a=0;a<num.size();a++){
        if(num[a] == '4' || num[a] == '7'){     //(num[a] == '4' || '7') '||' needs a boolean on each side, so '7' alone gets treated as "is this non-zero?"                                         
            count++;                            // — which is always true. So this condition is always true, no matter what character num[a] actually is.
        }
    }
    unsigned long long n = stoull(num);         //Explanation Below
    if(count == num.size()){
        cout<<"YES";
    }
    else if( n % 4 == 0 || n % 7 == 0){
        cout<<"YES";
    }
    else{
        cout<<"NO";
    }
    return 0;
}

