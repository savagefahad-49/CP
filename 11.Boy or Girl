#include<iostream>
#include<string>
using namespace std;
int main(){
    string n;
    cin>>n;
    int p = n.size()-1;
    int count = 0;
    sort(n.begin(),n.end());      //First time using sort();
    for(int i = 0; i<p; i++){
        if(n[i]!=n[i+1]){
            count++;
        }
    }
    count++;
    if(count%2==0){
        cout<<"CHAT WITH HER!";
    }
    else{
        cout<<"IGNORE HIM!";
    }
    return 0;
}
